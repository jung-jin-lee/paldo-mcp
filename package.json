{
  "name": "paldo-mcp",
  "version": "0.3.0",
  "private": true,
  "description": "MCP server for NVIDIA Nemotron-Personas-Korea — 7M Korean personas, callable from Claude Code",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
